<div class="agent-checkbox-item" style="display: flex; align-items: center; gap: 12px; padding: 10px; border-bottom: 1px solid #eee;">
    <input type="checkbox" class="agent-checkbox" data-agent-id="{{ id }}" data-agent-name="{{ fullname }}" data-agent-position="{{ position }}">
    <img src="{{ image }}" alt="" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;">
    <div>
        <div style="font-weight: 500;">{{ fullname }}</div>
        <div style="font-size: 0.8rem; color: #888;">{{ position }}</div>
    </div>
</div>