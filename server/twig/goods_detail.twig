<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes">
    <title>{{ goods.name }} - Светлый Путь</title>
    <link rel="stylesheet" href="src/css/goods_detail.css">
    <link rel="stylesheet" href="../src/css/index.css">
    <link rel="stylesheet" href="../src/css/nav.css">
    <link rel="stylesheet" href="../src/css/footer.css">
    <link rel="stylesheet" href="../src/css/modal.css">
    <link rel="stylesheet" href="../src/css/toasts.css">
    <link rel="icon" href="../logo.png" type="image/png">
</head>
<body>
<!-- Хедер -->
<header class="header">
    <div class="container">
        <div class="logo-container">
            <img src="../logo.png" alt="Светлый Путь" class="logo-img">
            <span class="logo-text">Светлый Путь</span>
        </div>
        <button class="burger" id="burger">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <nav class="nav" id="nav">
            <a href="../index.php">Главная</a>
            <a href="index.php" class="active">Товары</a>
            <a href="../services/">Услуги</a>
            <a href="../agents/">Агенты</a>
            <a href="../calculator/">Калькулятор</a>
            <a href="../autopark/">Автопарк</a>
            <a href="../orders/">Заказы</a>
            <a onclick="openModal()" class="btn-light">Связаться</a>
        </nav>
    </div>
    <div class="overlay" id="overlay"></div>
</header>

<main>
    <!-- Хлебные крошки -->
    <div class="breadcrumbs">
        <div class="container">
            <a href="../index.php">Главная</a>
            <span class="separator">›</span>
            <a href="index.php">Товары</a>
            <span class="separator">›</span>
            <span class="current">{{ goods.name }}</span>
        </div>
    </div>

    <!-- Детальная информация -->
    <section class="goods-detail">
        <div class="container">
            <div class="goods-detail-grid">
                <!-- Левая колонка: фото -->
                <div class="goods-gallery">
                    <div class="main-image">
                        <img src="../src/images/goods/{{ goods.image_path }}" alt="{{ goods.name }}" id="mainImage">
                    </div>

                    <div class="goods-description">
                        <h3>Описание</h3>
                        <p>{{ goods.description_full }}</p>
                    </div>
                </div>

                <!-- Правая колонка: информация -->
                <div class="goods-info">
                    <div class="goods-category-badge">{{ goods.category }}</div>
                    <h1 class="goods-title">{{ goods.name }}</h1>

                    <div class="goods-price-block">
                        <div class="goods-price">{{ goods.price }} ₽</div>
                        <div class="goods-price-note">за единицу товара</div>
                    </div>

                    <div class="goods-availability">
                        <span class="availability-badge available">В наличии</span>
                        <span class="stock-count">{{ goods.total_stock }} шт.</span>
                    </div>

                    <div class="goods-actions-detail">
                        <button class="btn-outline btn-large" onclick="addToCart('goods', {{ goods.id }})">Добавить в калькулятор</button>
                    </div>

                    <div class="goods-specs">
                        <h3>Характеристики</h3>
                        <div class="specs-grid">
                            <div class="spec-item">
                                <span class="spec-label">Материал</span>
                                <span class="spec-value">{{ goods.material }}</span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Категория</span>
                                <span class="spec-value">{{ goods.category }}</span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Размеры</span>
                                <span class="spec-value">{{ goods.sizes }} см</span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Вес</span>
                                <span class="spec-value">{{ goods.weight }} кг</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Похожие товары -->
    <section class="similar-goods">
        <div class="container">
            <h2>Похожие товары</h2>
            <div class="section-divider"></div>
            <div class="similar-grid">
                <div class="similar-card">
                    <div class="similar-image">
                        <img src="../src/images/goods/grob_duboviy.jpg" alt="Гроб дубовый">
                    </div>
                    <div class="similar-content">
                        <h3>Гроб дубовый</h3>
                        <div class="similar-price">35 000 ₽</div>
                        <a href="#" class="btn-outline">Подробнее</a>
                    </div>
                </div>
                <div class="similar-card">
                    <div class="similar-image">
                        <img src="../src/images/goods/grob_krasnoye_derevo.jpg" alt="Гроб красное дерево">
                    </div>
                    <div class="similar-content">
                        <h3>Гроб красное дерево</h3>
                        <div class="similar-price">65 000 ₽</div>
                        <a href="#" class="btn-outline">Подробнее</a>
                    </div>
                </div>
                <div class="similar-card">
                    <div class="similar-image">
                        <img src="../src/images/goods/krest_2.jpg" alt="Крест деревянный">
                    </div>
                    <div class="similar-content">
                        <h3>Крест деревянный</h3>
                        <div class="similar-price">2 800 ₽</div>
                        <a href="#" class="btn-outline">Подробнее</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
{{ page_end }}
<script src="../src/js/jquery.min.js"></script>
<script src="../src/js/toasts.js"></script>
<script src="../src/js/modal.js"></script>
<script src="src/js/goods_detail.js"></script>
<script src="../src/js/cartHelper.js"></script>
</body>
</html>