<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5, user-scalable=yes">
    <title>{{ vehicle.name }} - Светлый Путь</title>
    <link rel="stylesheet" href="src/css/vehicle.css">
    <link rel="stylesheet" href="../src/css/nav.css">
    <link rel="stylesheet" href="../src/css/modal.css">
    <link rel="stylesheet" href="../src/css/footer.css">
    <link rel="stylesheet" href="../src/css/toasts.css">
    <link rel="icon" href="../logo.png" type="image/png">
</head>
<body>
<!-- Хедер -->
<header class="header">
    <div class="container">
        <div class="logo-container">
            <img src="../logo.png" alt="Светлый Путь" class="logo-img">
            <span class="logo-text">Светлый Путь</span>
        </div>
        <button class="burger" id="burger">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <nav class="nav" id="nav">
            <a href="../index.php">Главная</a>
            <a href="../goods/">Товары</a>
            <a href="../services/">Услуги</a>
            <a href="../agents/">Агенты</a>
            <a href="../calculator/">Калькулятор</a>
            <a href="../autopark/" class="active">Автопарк</a>
            <a href="../orders/">Заказы</a>
            <a onclick="openModal()" class="btn-light">Связаться</a>
        </nav>
    </div>
    <div class="overlay" id="overlay"></div>
</header>

<main>
    <!-- Хлебные крошки -->
    <div class="breadcrumbs">
        <div class="container">
            <a href="../index.php">Главная</a>
            <span class="separator">›</span>
            <a href="../autopark/">Автопарк</a>
            <span class="separator">›</span>
            <span class="current">{{ vehicle.name }}</span>
        </div>
    </div>

    <!-- Детальная информация об авто -->
    <section class="vehicle-detail">
        <div class="container">
            <div class="vehicle-detail-grid">
                <!-- Левая колонка: галерея -->
                <div class="vehicle-gallery">
                    <div class="main-image">
                        <img src="{{ vehicle.images.main }}" alt="{{ vehicle.name }}" id="mainImage">
                    </div>
                    <p style="font-weight: 500; font-size: 1.2rem; padding: 6px 0">Все фотографии</p>
                    <div class="thumbnail-grid">
                        <div class="thumbnail active">
                            <img src="{{ vehicle.images.main }}" alt="{{ vehicle.name }}" onclick="changeImage(this)">
                        </div>
                        {% if vehicle.images.additional_images is not empty %}
                            {% set additional_images_count = 0 %}
                            {% for item in vehicle.images.additional_images %}
                                {% set additional_images_count = additional_images_count + 1 %}
                            {% endfor %}
                            {% if additional_images_count > 0 %}
                                {% for additional_image in vehicle.images.additional_images %}
                                    <div class="thumbnail">
                                        <img src="{{ additional_image }}" alt="{{ vehicle.name }}" onclick="changeImage(this)">
                                    </div>
                                {% endfor %}
                            {% endif %}
                        {% endif %}
                    </div>
                </div>

                <!-- Правая колонка: информация -->
                <div class="vehicle-info">
                    <h1 class="vehicle-title">{{ vehicle.name }}</h1>
                    <div class="vehicle-category-badge">{{ vehicle.category_name }}</div>

                    <div class="vehicle-price-block">
                        <div class="vehicle-current-price">от {{ vehicle.price|number_format(0, '', ' ') }} ₽</div>
                        <div class="vehicle-price-note">за мероприятие</div>
                    </div>

                    <div class="vehicle-availability">
                        <span class="availability-badge available">В наличии</span>
                        <span class="stock-count">{{ vehicle.available_stock }} автомобилей</span>
                    </div>

                    <div class="vehicle-actions-detail">
                        <button class="btn-outline btn-large" onclick="addToCart('transport', {{ vehicle.id }})">Добавить в расчёт</button>
                    </div>

                    <!-- Характеристики -->
                    <div class="vehicle-specs">
                        <h3>Характеристики</h3>
                        <div class="specs-grid">
                            <div class="spec-item">
                                <span class="spec-label">Цвет</span>
                                <span class="spec-value">{{ vehicle.color }}</span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Количество мест</span>
                                <span class="spec-value">{{ vehicle.seats }}</span>
                            </div>
                        </div>
                    </div>

                    <!-- Описание -->
                    <div class="vehicle-description">
                        <h3>Описание</h3>
                        {{ vehicle.description_full|raw }}
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Похожие автомобили -->
    {% if similar_vehicles is not empty %}
            <section class="similar-vehicles">
                <div class="container">
                    <h2>Похожие автомобили</h2>
                    <div class="section-divider"></div>

                    <div class="similar-grid">
                        {% for similar in similar_vehicles %}
                            <div class="similar-card">
                                <div class="similar-image">
                                    <img src="../src/images/vehicles/{{ similar.image_path }}/main.jpg" alt="{{ similar.name }}">
                                </div>
                                <div class="similar-content">
                                    <h3>{{ similar.name }}</h3>
                                    <div class="similar-price">от {{ similar.price|number_format(0, '', ' ') }} ₽</div>
                                    <a href="vehicle.php?id={{ similar.id }}" class="btn-outline">Подробнее</a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
    {% endif %}
</main>
{{ page_end }}
<script src="../src/js/jquery.min.js"></script>
<script src="../src/js/toasts.js"></script>
<script src="../src/js/modal.js"></script>
<script src="../src/js/cartHelper.js"></script>
<script src="src/js/vehicle.js"></script>
</body>
</html>